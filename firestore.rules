rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper standard functions
    function isAuthenticated() {
      return request.auth != null;
    }

    match /customers/{customerId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || resource.data.userId == 'admin_btn_shared_public';
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || resource.data.userId == 'admin_btn_shared_public';
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || request.resource.data.userId == 'admin_btn_shared_public';
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) || (resource.data.userId == 'admin_btn_shared_public' && request.resource.data.userId == 'admin_btn_shared_public');
    }

    match /targets/{targetId} {
      allow read, write: if (isAuthenticated() && targetId.startsWith(request.auth.uid + "_")) || targetId.startsWith("admin_btn_shared_public_");
    }
  }
}
